{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ProjectTaskCreate",
  "title": "ProjectTaskCreate",
  "type": "object",
  "required": [
    "TaskName",
    "ProjectId",
    "StartDate"
  ],
  "properties": {
    "TaskName": {
      "type": "string"
    },
    "ProjectId": {
      "type": "integer"
    },
    "ParentTaskId": {
      "type": "integer"
    },
    "StartDate": {
      "type": "string",
      "format": "date"
    },
    "EndDate": {
      "type": "string",
      "format": "date"
    },
    "PlannedEffort": {
      "type": "number",
      "format": "double"
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AnnouncementCreate",
  "title": "AnnouncementCreate",
  "type": "object",
  "required": [
    "Subject",
    "StartDate"
  ],
  "properties": {
    "Subject": {
      "type": "string"
    },
    "Description": {
      "type": "string"
    },
    "StartDate": {
      "type": "string",
      "format": "date"
    },
    "EndDate": {
      "type": "string",
      "format": "date"
    },
    "Severity": {
      "type": "string",
      "enum": [
        "Information",
        "Warning",
        "Critical"
      ]
    }
  }
}